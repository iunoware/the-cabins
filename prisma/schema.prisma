generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ContactMessageStatus {
  NEW
  CONTACTED
  RESOLVED
  SPAM
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
}

/**
 * PROJECT MODULE
 */

model ProjectCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  badgeLabel  String?
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]

  @@map("projectCategories")
}

model Project {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String?  @db.Text
  categoryId      String
  city            String?
  country         String?
  status          String?
  isFeatured      Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category     ProjectCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images       ProjectImage[]
  testimonials ProjectTestimonial[]

  @@index([categoryId])
  @@map("projects")
}

model ProjectTestimonial {
  id          String   @id @default(cuid())
  projectId   String
  clientName  String
  designation String?
  companyName String?
  testimonial String   @db.Text
  rating      Int      @default(5)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([isActive])
  @@map("projectTestimonials")
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  imageUrl  String
  altText   String?
  isCover   Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("projectImages")
}

/**
 * CONTACT MESSAGE MODULE
 */

model ContactMessage {
  id          String               @id @default(cuid())
  fullName    String
  phoneNumber String
  email       String
  subject     String
  message     String               @db.Text
  status      ContactMessageStatus @default(NEW)
  isRead      Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([status])
  @@index([isRead])
  @@map("contactMessages")
}

/**
 * TESTIMONIAL MODULE
 */

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  subheading  String?
  testimonial String   @db.Text
  rating      Int      @default(5)
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isFeatured])
  @@index([isActive])
  @@map("testimonials")
}

/**
 * USERS MODULE
 */

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  phone        String?   @unique
  role         UserRole  @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdBy    User?  @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[] @relation("UserCreatedBy")

  @@index([role])
  @@index([isActive])
  @@map("users")
}

/**
 * PRODUCT MODULE
 */

model ProductCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  image       String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  badge       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  families ProductFamily[]

  @@index([active])
  @@map("productCategories")
}

model ProductFamily {
  id               String   @id @default(cuid())
  categoryId       String
  name             String
  slug             String   @unique
  shortDescription String
  thumbnail        String
  featured         Boolean  @default(false)
  popular          Boolean  @default(false)
  active           Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category ProductCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@index([categoryId])
  @@index([featured])
  @@index([popular])
  @@index([active])
  @@map("productFamilies")
}

model ProductVariant {
  id               String   @id @default(cuid())
  familyId         String
  name             String
  slug             String   @unique
  shortDescription String
  description      String   @db.Text
  price            Decimal? @db.Decimal(10, 2)
  originalPrice    Decimal? @db.Decimal(10, 2)
  discountedPrice  Decimal? @db.Decimal(10, 2)
  currency         String   @default("AED")
  dimensions       String?
  capacity         String?
  material         String?
  warranty         String?
  brochure         String?
  model3d          String?
  ctaText          String?
  whatsappNumber   String?
  metaTitle        String?
  metaDescription  String?  @db.Text
  keywords         String?  @db.Text
  ogImage          String?
  thumbnail        String
  featured         Boolean  @default(false)
  active           Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  family         ProductFamily          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  images         ProductImage[]
  features       ProductFeature[]
  specifications ProductSpecification[]
  applications   ProductApplication[]
  faqs           ProductFAQ[]

  @@index([familyId])
  @@index([featured])
  @@index([active])
  @@map("productVariants")
}

model ProductImage {
  id        String   @id @default(cuid())
  variantId String
  imageUrl  String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@map("productImages")
}

model ProductFeature {
  id          String  @id @default(cuid())
  variantId   String
  title       String
  description String  @db.Text
  icon        String?
  sortOrder   Int     @default(0)

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@map("productFeatures")
}

model ProductSpecification {
  id        String @id @default(cuid())
  variantId String
  parameter String
  value     String @db.Text
  sortOrder Int    @default(0)

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@map("productSpecifications")
}

model ProductApplication {
  id        String  @id @default(cuid())
  variantId String
  title     String
  icon      String?
  sortOrder Int     @default(0)

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@map("productApplications")
}

model ProductFAQ {
  id        String @id @default(cuid())
  variantId String
  question  String
  answer    String @db.Text
  sortOrder Int    @default(0)

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@map("productFAQs")
}
